# Baby JubJub EdDSA private key for the agent owner (hex string)
# Generate with: python -m src keygen
OWNER_PRIVATE_KEY=

# Ethereum private key for contract deployment (hex, 0x-prefixed)
DEPLOYER_PRIVATE_KEY=

# Fernet encryption key for SQLite database (any strong passphrase)
ZK_DB_ENCRYPTION_KEY=

# Base chain RPC URLs (defaults to public RPCs if not set)
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
